classDiagram
    class User {
        +String userID
        +String name
        +String email
        +String phoneNumber
        +String address
        +addPet(pet) void
        +schedulePetWalk(pet, date) Schedule
        +trackAppointments() List~Task~
        +getTodayTasks() List~Task~
    }

    class Pet {
        +String petID
        +String animalType
        +String name
        +String ownerID
        +getPetDetails() String
        +getUpcomingTasks() List~Task~
    }

    class Task {
        +String taskID
        +String taskDescription
        +int taskDuration
        +String taskPriority
        +createTask() Task
        +updatePriority(priority) void
        +markComplete() void
        +getStatus() String
    }

    class Schedule {
        +String scheduleID
        +String scheduleDate
        +String taskID
        +String startTime
        +String endTime
        +String ownerID
        +addTask(task) void
        +removeTask(taskID) void
        +viewSchedule() List~Task~
        +generateDailyPlan() List~Task~
        +explainPlan() String
    }

    User "1" --> "0..*" Pet : owns
    User "1" --> "1" Schedule : has
    Schedule "1" --> "0..*" Task : contains
